{
  "manifest_version": 3,
  "name": "Chess.com to Lichess Import",
  "version": "0.1.0",
  "description": "Import the current Chess.com game into Lichess with one click.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": ["https://www.chess.com/*", "https://lichess.org/*"],
  "background": {
    "service_worker": "dist/service-worker.js"
  },
  "action": {
    "default_state": "disabled",
    "default_title": "Import Chess.com game to Lichess",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.chess.com/game/*",
        "https://www.chess.com/game/live/*"
      ],
      "js": ["dist/chess-com.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://lichess.org/paste*"],
      "js": ["dist/lichess.js"],
      "run_at": "document_idle"
    }
  ]
}